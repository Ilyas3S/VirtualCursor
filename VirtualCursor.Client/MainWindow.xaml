<Window x:Class="VirtualCursor.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Remote Client"
        Height="217" Width="400"
        WindowStartupLocation="CenterScreen">
    <StackPanel Margin="10">
        <TextBlock Text="Session ID сервера:" Margin="0 0 0 5"/>
        <TextBox x:Name="ServerSessionIdTextBox" Margin="0 0 0 10" Width="200"/>
        <TextBlock Text="IP-адрес сервера (необязательно):" Margin="0 0 0 5"/>
        <TextBox x:Name="IpTextBox" Margin="0 0 0 10" Text=""/>
        <Button x:Name="ConnectButton" Content="Подключиться" Click="ConnectButton_Click" Height="30"/>
        <TextBlock x:Name="StatusTextBlock" Text="Не подключен" Margin="0 10 0 0" Foreground="Red"/>
    </StackPanel>
</Window>