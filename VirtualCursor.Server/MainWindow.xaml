<Window x:Class="VirtualCursor.Server.MainWindow"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:local="clr-namespace:VirtualCursor.Server"
Title="VirtualCursor Server" Height="600" Width="800"
WindowStyle="None" AllowsTransparency="True" Background="Transparent" Topmost="True"
WindowState="Maximized">
    <Grid>
        <!-- Canvas для спрайтов -->
        <Canvas Name="MainCanvas">
            <!-- Спрайт локального курсора -->
            <Rectangle Name="LocalSprite" 
                       Width="32" Height="32" 
                       Fill="Green" Stroke="White" StrokeThickness="2"
                       Canvas.Left="0" Canvas.Top="0" Opacity="0.5"/>
            <!-- Спрайт удалённого курсора -->
            <Rectangle Name="RemoteSprite" 
Width="32" Height="32" 
Fill="Red" Stroke="Black" StrokeThickness="2"
Canvas.Left="0" Canvas.Top="0"/>
        </Canvas>
        <!-- Панель информации -->
        <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" 
Margin="10" Background="#CC000000">
            <TextBlock Name="SessionIdText" Foreground="White" FontSize="14" FontWeight="Bold"/>
            <TextBlock Name="StatusText" Foreground="#88FFFFFF" FontSize="12"/>
            <TextBlock Name="StatsText" Foreground="#66FFFFFF" FontSize="10"/>
            <TextBlock Text="F12 - показать/скрыть настройки" Foreground="#44FFFFFF" FontSize="10" Margin="0,5,0,0"/>
        </StackPanel>
        <!-- Настройки (скрыты по умолчанию) -->
        <Border Name="SettingsPanel" IsHitTestVisible="True"  
HorizontalAlignment="Right" VerticalAlignment="Top" 
Margin="10" Background="#DD222222" Padding="15" 
CornerRadius="8" Visibility="Collapsed"
Panel.ZIndex="999">
            <StackPanel Width="200">
                <TextBlock Text="Настройки трансляции" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBlock Text="FPS:" Foreground="#88FFFFFF" FontSize="11"/>
                <Slider Name="FpsSlider" Minimum="5" Maximum="30" Value="20" 
                        TickFrequency="5" IsSnapToTickEnabled="True"
                        Margin="0,2,0,10"/>
                <TextBlock Text="Качество JPEG:" Foreground="#88FFFFFF" FontSize="11"/>
                <Slider Name="QualitySlider" Minimum="20" Maximum="90" Value="70" 
                        TickFrequency="10" IsSnapToTickEnabled="True"
                        Margin="0,2,0,10"/>
                <TextBlock Text="Масштаб:" Foreground="#88FFFFFF" FontSize="11"/>
                <Slider Name="ScaleSlider" Minimum="1" Maximum="4" Value="2" 
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        Margin="0,2,0,10"/>
                <TextBlock Text="Трансляция:" Foreground="#88FFFFFF" FontSize="11"/>
                <ToggleButton Name="StreamToggle" Content="Включить" 
                              Checked="StreamToggle_Checked" Unchecked="StreamToggle_Unchecked"
                              Margin="0,5,0,0" Background="#4d6bfe" Foreground="White"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>